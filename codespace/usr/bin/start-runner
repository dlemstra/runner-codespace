#!/bin/sh
set -e

if [ -z "$$1" ]; then
    echo "The name of the runner type is not supplied"
    exit 1
fi

if [ -z "$TOKEN_FOR_ACTIONS" ]; then
    echo "The secret TOKEN_FOR_ACTIONS is not set"
    exit 1
fi

echo "Starting runner for $1"

inputs="{\"runner\":\"$1\",\"codespace\":\"$CODESPACE_NAME\""
if [ -n "$2" ]; then
  inputs="$inputs,\"container\":\"$2\""
fi
inputs="$inputs}"

curl -X POST \
  -H "Accept: application/vnd.github.v3+json" \
  -H "Authorization: token $TOKEN_FOR_ACTIONS" \
  https://api.github.com/repos/$GITHUB_REPOSITORY/actions/workflows/start-runner.yml/dispatches \
  -d "{\"ref\":\"main\",\"inputs\":$inputs}"

spin='-\|/'

i=0
tput civis
while ! nc -z localhost 4748; do
  i=$(( (i+1) % 4 ))
  printf "\rWaiting for port 4748 to open ${spin:$i:1}"
  sleep 0.1
done
tput cnorm

echo ""
sleep 1
. shell
